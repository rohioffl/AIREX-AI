# Database (PostgreSQL 15+)
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=airex
DATABASE_URL=postgresql+asyncpg://your_user:your_password@db:5432/airex

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
API_V1_STR=/api/v1
PROJECT_NAME="AIREX"
SECRET_KEY=generate_a_secure_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# AI Provider (LiteLLM)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# ── Cloud Providers ──────────────────────────────────────────
# AWS (SSM RunCommand for EC2 investigation)
# Leave empty to use instance IAM role (recommended on EC2/ECS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_PROFILE=                           # AWS CLI profile name (empty = default)
AWS_SSM_DOCUMENT=AWS-RunShellScript
AWS_SSM_TIMEOUT=30

# GCP (OS Login SSH + Log Explorer for GCE investigation)
# Leave empty to use Application Default Credentials (recommended on GCE/GKE)
GCP_PROJECT_ID=                        # e.g. my-gcp-project
GCP_ZONE=                              # e.g. asia-south1-a
GCP_SERVICE_ACCOUNT_KEY=               # path to SA JSON key (empty = use ADC)
GCP_OS_LOGIN_USER=                     # POSIX username (auto-resolved if empty)
GCP_LOG_EXPLORER_ENABLED=true

# SSH fallback (when SSM / OS Login not available)
SSH_KEY_PATH=                           # e.g. /home/ubuntu/.ssh/id_rsa
SSH_USER=ubuntu
SSH_PORT=22
SSH_TIMEOUT=15

# Webhook signature verification (empty = skip in dev)
WEBHOOK_SECRET=

# SaaS Multi-Tenancy
# Simulated Tenant ID for local development
DEV_TENANT_ID=00000000-0000-0000-0000-000000000000
