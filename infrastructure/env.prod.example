# Production environment contract
# Secrets should be loaded from AWS Secrets Manager at runtime.
# Non-secret config should be loaded from SSM Parameter Store.

# Non-secret config
APP_ENV=prod
CORS_ORIGINS=["https://airex.rohitpt.online"]
LLM_BASE_URL=https://litellm.rohitpt.online/v1
LLM_PRIMARY_MODEL=gemini-2.0-flash
LLM_FALLBACK_MODEL=nova-lite
LLM_EMBEDDING_MODEL=text-embedding
LANGFUSE_HOST=https://langfuse.rohitpt.online

# Secret names (Secrets Manager)
SM_BACKEND_DATABASE_URL=/airex/prod/backend/database_url
SM_BACKEND_REDIS_URL=/airex/prod/backend/redis_url
SM_BACKEND_SECRET_KEY=/airex/prod/backend/secret_key
SM_LITELLM_MASTER_KEY=/airex/prod/litellm/master_key
SM_LANGFUSE_DATABASE_URL=/airex/prod/langfuse/database_url
SM_LANGFUSE_NEXTAUTH_SECRET=/airex/prod/langfuse/nextauth_secret
SM_LANGFUSE_SALT=/airex/prod/langfuse/salt
SM_LANGFUSE_PUBLIC_KEY=/airex/prod/langfuse/public_key
SM_LANGFUSE_SECRET_KEY=/airex/prod/langfuse/secret_key
