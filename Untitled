# Redirect HTTP → HTTPS
server {
    if ($host = airex.ankercloud.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name airex.ankercloud.com 15.207.2.175;

    # Let's Encrypt challenge
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://airex.ankercloud.com$request_uri;
    }


}

# HTTPS — will be updated by certbot with real certs
server {
    listen 443 ssl;
    server_name airex.ankercloud.com;
    ssl_certificate /etc/letsencrypt/live/airex.ankercloud.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/airex.ankercloud.com/privkey.pem; # managed by Certbot

    # Webhooks (Site24x7, etc.)
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Content-Type $content_type;
        proxy_read_timeout 60s;
    }

    # SSE stream — long-lived connection
    location /api/v1/incidents/stream {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # Frontend (Vite build / dev)
    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

}