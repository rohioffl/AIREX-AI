# OpenClaw — copy into repo-root .env for AIREX (API/worker) and/or export for Docker Compose.
# See README.md and docs/openclaw_local_setup.md

OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TOOL_SERVER_TOKEN=
OPENCLAW_REQUEST_TIMEOUT=60
OPENCLAW_AGENT_ID=controller
AIREX_TOOLS_BASE_URL=http://host.docker.internal:8000
AIREX_TOOL_TIMEOUT_MS=30000

# Google Gemini (OpenClaw native `google/*` models) — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Docker Compose (services/openclaw/docker-compose.yml)
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_TZ=UTC
# Override persistence paths (defaults: repo-root .local/openclaw/{config,workspace})
# OPENCLAW_CONFIG_DIR=/abs/path/to/config
# OPENCLAW_WORKSPACE_DIR=/abs/path/to/workspace
