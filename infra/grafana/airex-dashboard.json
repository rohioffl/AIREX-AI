{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Incident Pipeline Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Incidents Created (rate/5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(airex_incident_created_total[5m])) by (severity)",
          "legendFormat": "{{ severity }}"
        }
      ]
    },
    {
      "title": "State Transitions (rate/5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(airex_state_transition_total[5m])) by (to_state)",
          "legendFormat": "→ {{ to_state }}"
        }
      ]
    },
    {
      "title": "Active Incidents",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(airex_active_incidents)", "legendFormat": "Active" }
      ]
    },
    {
      "title": "DLQ Size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(airex_dlq_size)", "legendFormat": "DLQ" }
      ]
    },
    {
      "title": "Circuit Breaker",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        { "expr": "airex_circuit_breaker_state", "legendFormat": "State" }
      ]
    },
    {
      "title": "AI Success Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(airex_ai_failure_total[5m])) / (sum(rate(airex_ai_request_total[5m])) + 0.001))) * 100",
          "legendFormat": "Success %"
        }
      ]
    },
    {
      "title": "AI / LLM Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "AI Request Latency (P50/P95/P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(airex_ai_request_duration_seconds_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(airex_ai_request_duration_seconds_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(airex_ai_request_duration_seconds_bucket[5m]))", "legendFormat": "P99" }
      ]
    },
    {
      "title": "AI Requests vs Failures",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "sum(rate(airex_ai_request_total[5m]))", "legendFormat": "Requests/s" },
        { "expr": "sum(rate(airex_ai_failure_total[5m]))", "legendFormat": "Failures/s" }
      ]
    },
    {
      "title": "Execution Engine",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Execution Duration (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(airex_execution_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 Duration"
        }
      ]
    },
    {
      "title": "Executions by Status",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "sum(airex_execution_total) by (status)",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "title": "HTTP Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "HTTP Request Latency by Path (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(airex_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{ path }}"
        }
      ]
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(airex_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(airex_http_request_duration_seconds_count[5m]))",
          "legendFormat": "5xx Rate"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["airex", "sre", "incidents"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AIREX — Incident Pipeline",
  "uid": "airex-pipeline",
  "version": 1
}
