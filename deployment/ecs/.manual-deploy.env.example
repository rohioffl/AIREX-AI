# Copy to deployment/ecs/.manual-deploy.env and fill values.

# Core
AWS_REGION=ap-south-1
ECS_CLUSTER=airex-prod-cluster
ECS_SERVICE_API=airex-prod-api
ECS_SERVICE_WORKER=airex-prod-worker
ECS_SERVICE_LITELLM=airex-prod-litellm
ECS_SERVICE_LANGFUSE=airex-prod-langfuse

# ECR repos (image tag comes from current git sha unless IMAGE_TAG is set)
ECR_API_REPO=airex-prod-api
ECR_WORKER_REPO=airex-prod-worker
ECR_LITELLM_REPO=airex-prod-litellm
LANGFUSE_IMAGE=public.ecr.aws/langfuse/langfuse:2

# ECS task definition fields used by render-task-defs.sh
EXECUTION_ROLE_ARN=
TASK_ROLE_ARN=
TASKDEF_FAMILY_API=
TASKDEF_FAMILY_WORKER=
TASKDEF_FAMILY_LITELLM=
TASKDEF_FAMILY_LANGFUSE=
LOG_GROUP_API=
LOG_GROUP_WORKER=
LOG_GROUP_LITELLM=
LOG_GROUP_LANGFUSE=
SECRET_DATABASE_URL_ARN=
SECRET_REDIS_URL_ARN=
SECRET_APP_SECRET_KEY_ARN=
SECRET_LITELLM_MASTER_KEY_ARN=
SECRET_SITE24X7_CLIENT_SECRET_ARN=
SECRET_SITE24X7_REFRESH_TOKEN_ARN=
SECRET_EMAIL_SMTP_PASSWORD_ARN=
SECRET_LANGFUSE_PUBLIC_KEY_ARN=
SECRET_LANGFUSE_SECRET_KEY_ARN=
SECRET_LANGFUSE_DATABASE_URL_ARN=
SECRET_LANGFUSE_NEXTAUTH_SECRET_ARN=
SECRET_LANGFUSE_SALT_ARN=
LLM_BASE_URL=
LLM_PRIMARY_MODEL=vertex_ai/gemini-2.0-flash
LLM_FALLBACK_MODEL=vertex_ai/gemini-2.0-flash-lite
LLM_EMBEDDING_MODEL=text-embedding-3-large
CORS_ORIGINS=https://airex.ankercloud.com
FRONTEND_URL=https://airex.ankercloud.com
GOOGLE_OAUTH_CLIENT_ID=
SITE24X7_ENABLED=true
SITE24X7_CLIENT_ID=
SITE24X7_BASE_URL=https://www.site24x7.in/api
SITE24X7_ACCOUNTS_URL=https://accounts.zoho.in
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_FROM=
LANGFUSE_HOST=
NEXTAUTH_URL=

# Migration + frontend deploy helpers
BACKEND_DATABASE_URL_SECRET_ID=/airex/prod/backend/database_url
FRONTEND_GOOGLE_CLIENT_ID_SECRET_ID=/airex/prod/frontend/google_oauth_client_id
FRONTEND_BUCKET=
CLOUDFRONT_DISTRIBUTION_ID=
