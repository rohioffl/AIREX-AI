{
  "pipeline": {
    "name": "airex-prod",
    "roleArn": "arn:aws:iam::547361935557:role/airex-prod-codepipeline-role",
    "artifactStore": {
      "type": "S3",
      "location": "airex-prod-codepipeline-547361935557"
    },
    "version": 1,
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "GitHubSource",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "CodeStarSourceConnection",
              "version": "1"
            },
            "configuration": {
              "ConnectionArn": "arn:aws:codestar-connections:ap-south-1:547361935557:connection/e18dc1b1-4de5-4187-84f0-254e5a4c3e99",
              "FullRepositoryId": "anker-cloud/airex",
              "BranchName": "main"
            },
            "outputArtifacts": [
              {
                "name": "SourceArtifact"
              }
            ],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "BuildImages",
        "actions": [
          {
            "name": "BuildApiImage",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-images-api"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              }
            ],
            "outputArtifacts": [
              {
                "name": "ApiImageArtifact"
              }
            ],
            "runOrder": 1
          },
          {
            "name": "BuildWorkerImage",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-images-worker"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              }
            ],
            "outputArtifacts": [
              {
                "name": "WorkerImageArtifact"
              }
            ],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "DbMigration",
        "actions": [
          {
            "name": "RunDbMigration",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-db-migrate"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              }
            ],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "DeployEcs",
        "actions": [
          {
            "name": "DeployApi",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-deploy-api",
              "PrimarySource": "SourceArtifact"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              },
              {
                "name": "ApiImageArtifact"
              }
            ],
            "runOrder": 1
          },
          {
            "name": "DeployWorker",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-deploy-worker",
              "PrimarySource": "SourceArtifact"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              },
              {
                "name": "WorkerImageArtifact"
              }
            ],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "DeployFrontend",
        "actions": [
          {
            "name": "DeployFrontend",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "airex-prod-frontend"
            },
            "inputArtifacts": [
              {
                "name": "SourceArtifact"
              }
            ],
            "runOrder": 1
          }
        ]
      }
    ]
  }
}
