{
  "family": "__TASKDEF_FAMILY_WORKER__",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "__EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "__WORKER_IMAGE__",
      "essential": true,
      "command": ["arq", "app.core.worker.WorkerSettings"],
      "environment": [
        { "name": "AWS_REGION", "value": "__AWS_REGION__" },
        { "name": "LLM_BASE_URL", "value": "__LLM_BASE_URL__" },
        { "name": "LLM_PRIMARY_MODEL", "value": "__LLM_PRIMARY_MODEL__" },
        { "name": "LLM_FALLBACK_MODEL", "value": "__LLM_FALLBACK_MODEL__" },
        { "name": "LLM_EMBEDDING_MODEL", "value": "__LLM_EMBEDDING_MODEL__" },
        { "name": "FRONTEND_URL", "value": "__FRONTEND_URL__" },
        { "name": "SITE24X7_ENABLED", "value": "__SITE24X7_ENABLED__" },
        { "name": "SITE24X7_CLIENT_ID", "value": "__SITE24X7_CLIENT_ID__" },
        { "name": "SITE24X7_BASE_URL", "value": "__SITE24X7_BASE_URL__" },
        { "name": "SITE24X7_ACCOUNTS_URL", "value": "__SITE24X7_ACCOUNTS_URL__" },
        { "name": "EMAIL_FROM", "value": "__EMAIL_FROM__" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "__SECRET_DATABASE_URL_ARN__" },
        { "name": "REDIS_URL", "valueFrom": "__SECRET_REDIS_URL_ARN__" },
        { "name": "LLM_API_KEY", "valueFrom": "__SECRET_LITELLM_MASTER_KEY_ARN__" },
        { "name": "SITE24X7_CLIENT_SECRET", "valueFrom": "__SECRET_SITE24X7_CLIENT_SECRET_ARN__" },
        { "name": "SITE24X7_REFRESH_TOKEN", "valueFrom": "__SECRET_SITE24X7_REFRESH_TOKEN_ARN__" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "__LOG_GROUP_WORKER__",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
